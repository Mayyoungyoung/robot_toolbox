<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    
    <material name="table_mat" rgba="0.5 0.3 0.1 1" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light name="light1" pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <body name="table" pos="0.6 0 0.2">
      <geom name="table_geom" size="0.3 0.45 0.2" type="box" rgba="0.6 0.4 0.2 1"/>
    </body>

    <body pos="0.6 0 1.5" mocap="true" euler="0 0 0">
      <geom type="box" size="0.01 0.05 0.01" rgba=".1 .5 .1 1"/>
      <camera name="cam" mode="fixed" fovy="45"/>
    </body>

    <body name="target_cube" pos="0.5 0 0.5">
       <freejoint/>
       <geom name="target_geom" type="box" size="0.02 0.02 0.02" rgba="1 0 0 1"/>
    </body>

    <body name="distractor_1" pos="0.7 0.1 0.5">
       <freejoint/>
       <geom name="distractor_geom_1" type="cylinder" size="0.02 0.05" rgba="0 0 1 1"/>
    </body>
    
    <body name="distractor_2" pos="0.6 -0.1 0.5">
       <freejoint/>
       <geom name="distractor_geom_2" type="sphere" size="0.03" rgba="0 1 0 1"/>
    </body>

    <body name="distractor_3" pos="0.4 -0.2 0.5">
       <freejoint/>
       <geom name="distractor_geom_3" type="sphere" size="0.03" rgba="0 1 0 1"/>
    </body>

    <body name="distractor_4" pos="0.5 0.15 0.5">
       <freejoint/>
       <geom name="distractor_geom_4" type="sphere" size="0.03" rgba="0 1 0 1"/>
    </body>

    <body name="distractor_5" pos="0.8 -0.15 0.5">
       <freejoint/>
       <geom name="distractor_geom_5" type="cylinder" size="0.02 0.05" rgba="0 0 1 1"/>
    </body>

    <body name="distractor_6" pos="0.35 0.4 0.5">
       <freejoint/>
       <geom name="distractor_geom_6" type="cylinder" size="0.02 0.05" rgba="0 0 1 1"/>
    </body>

  </worldbody>
</mujoco>