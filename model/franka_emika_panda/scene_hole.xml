<mujoco model="panda_peg_hole">
    <option integrator="implicit" 
            timestep="0.001" 
            gravity="0 0 -9.81" 
            cone = "elliptic"
            iterations="300"
            tolerance="1e-12"
            />

  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <body name="top_camera"  pos="1.9 0 0.7" euler="0 0 0">  
          <camera name="top_camera" pos="0. 0. 0." mode="fixed" quat="0.56 0.43 0.43 0.56" fovy="45"/>
          <geom type="box" size="0.01 0.1 0.02" rgba="0. 1.0 0. 0.6" class="visual"/>
    </body>

  <body name="peg" pos="0.5 0 0.04">
    <freejoint name="peg"/>
    <geom name="peg_geom_down" pos="0 0 0" size="0.02 0.02 0.02" type="box" rgba="1 0 0 1" mass="0.005" friction="30.0 0.15 0.05" condim="4"/>
    <geom name="peg_geom_up" pos="0 0 0.045" size="0.02 0.02 0.025" type="box" rgba="0 0 1 1" mass="0.005" friction="30.0 0.15 0.05" solref="0.003 1"
          solimp="0.95 0.99 0.001" condim="4"/>
  </body>

  <body name="hole" pos="0.7 0 0.03">
    <geom name="hole_left" type="box" pos="-0.031 0 0" size="0.01 0.041 0.02" rgba="0 1 0 1"/>
    <geom name="hole_right" type="box" pos="0.031 0 0" size="0.01 0.041 0.02" rgba="0 1 0 1"/>
    <geom name="hole_front" type="box" pos="0 0.031 0" size="0.021 0.01 0.02" rgba="0 1 0 1"/>
    <geom name="hole_back" type="box" pos="0 -0.031 0" size="0.021 0.01 0.02" rgba="0 1 0 1"/>
  </body>


  </worldbody>

    <keyframe>
        <key
  name="grasp_home"
  qpos="1.89918e-16 -0.784093 0.000184611 -2.36231 -0.00031656 1.56986 0.785 0.0199969 0.0199969 0.306079 -3.20559e-05 0.42704 0.999997 -0.000221118 -0.00243535 0.000266194"
  ctrl="0 -0.785 0 -2.356 0 1.571 0.785 0"
    />    
</keyframe>

</mujoco>