<mujoco model="sorting scene">
  <option integrator="implicitfast" timestep="0.001" iterations="100" noslip_iterations="50" />
  <include file="ur5e_gripper_camera.xml"/>

  <statistic center="0.3 0 0.4" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.5 0.3 0.1 1" reflectance="0.1"/>
    <material name="table_mat_2" rgba="0.3 0.3 0.2 1" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="table_1" pos="-0.6 -0.6 0.02">
        <geom name="table_geom_1" size="0.3 0.35 0.02" type="box" material="table_mat" condim="3" friction="1 0.005 0.0001"/>
    </body>

    <body name="table_2" pos="-0.6 0.5 0.02">
        <geom name="table_geom_2" size="0.3 0.35 0.02" type="box" material="table_mat_2" condim="3" friction="1 0.005 0.0001"/>
    </body>

    <body name="cube" pos="-0.5 -0.45 0.06">
      <freejoint/> <geom name="cube" size="0.02 0.02 0.02" type="box" rgba="1 0 0 1" mass="0.1" condim="3" friction="1 0.005 0.0001"/>
    </body>

    <body name="cube2" pos="-0.7 -0.6 0.085">
      <freejoint/> <geom name="cube2" size="0.03 0.02 0.04" type="box" rgba="0 1 0 1" mass="0.1" condim="3" friction="1 0.005 0.0001"/>
    </body>

    <body name="sphere" pos="-0.4 -0.7 0.1">
      <freejoint/> <geom name="big_white_sphere" type="sphere" size="0.03" rgba="1 1 1 1" mass="1.0" condim="3" friction="1 0.005 0.0001"/>
    </body>

  </worldbody>
</mujoco>